<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/tech_accent_cyan" />
            <stroke android:width="2dp" android:color="@color/tech_accent_blue" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/tech_border" />
            <stroke android:width="1dp" android:color="@color/tech_accent_blue" />
        </shape>
    </item>
</selector>
