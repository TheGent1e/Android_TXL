<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Txl" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/tech_accent_blue</item>
        <item name="colorPrimaryVariant">@color/tech_bg_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/tech_accent_cyan</item>
        <item name="colorSecondaryVariant">@color/tech_accent_purple</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/tech_bg_primary</item>
        <!-- Background colors -->
        <item name="android:windowBackground">@color/tech_bg_primary</item>
        <item name="android:colorBackground">@color/tech_bg_primary</item>
    </style>

    <style name="Theme.Txl" parent="Base.Theme.Txl" />
</resources>
