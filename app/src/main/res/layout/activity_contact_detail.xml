<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <ImageView
                android:id="@+id/iv_avatar_detail"
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:src="@drawable/circle_avatar"
                android:contentDescription="@string/avatar"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_neon_circle"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp" />

            <TextView
                android:id="@+id/tv_change_avatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="点击更换头像"
                android:textSize="12sp"
                android:textColor="@color/text_muted" />

            <TextView
                android:id="@+id/tv_name_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/neon_cyan"
                android:letterSpacing="0.05" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/glass_border" />

        <LinearLayout
            android:id="@+id/ll_phones_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />

        <LinearLayout
            android:id="@+id/ll_note_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_glass_card"
            android:layout_margin="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/note"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_note_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="16sp"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp"
            android:gravity="center"
            android:spacing="16dp">

            <Button
                android:id="@+id/btn_edit_detail"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/edit"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_neon_button_cyan"
                android:textColor="#0D1117"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_edit"
                android:drawableTint="#0D1117"
                android:drawablePadding="8dp" />

            <Button
                android:id="@+id/btn_delete_detail"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="@string/delete"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_neon_button_red"
                android:textColor="#0D1117"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_delete"
                android:drawableTint="#0D1117"
                android:drawablePadding="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp"
            android:gravity="center">

            <Button
                android:id="@+id/btn_dial_detail"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_neon_circle_green"
                android:backgroundTint="@null"
                android:textColor="#0D1117"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_phone_green"
                android:drawableTint="#0D1117"
                android:contentDescription="@string/phone" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
